---
interface Props {
  defaultRegex: string;
  defaultFlags: string;
  testString: string;
}

const { defaultRegex, defaultFlags, testString } = Astro.props;

const flagDefs = [
  { flag: 'g', label: 'global' },
  { flag: 'i', label: 'ignore case' },
  { flag: 'm', label: 'multiline' },
];
---

<div id="regex-sandbox" class="grid gap-5 lg:grid-cols-2">
  <!-- Left: workspace panel -->
  <section class="flex flex-col gap-4 rounded-xl border border-zinc-800 bg-zinc-900/40 p-5">
    <div>
      <label for="rx-pattern" class="mb-2 flex items-center justify-between text-sm font-semibold text-zinc-200">
        Regex formula
        <button
          type="button"
          data-el="copy"
          class="rounded-md border border-zinc-700 px-2 py-0.5 font-mono text-xs text-zinc-400 transition hover:border-zinc-500 hover:text-zinc-100"
        >
          copy
        </button>
      </label>
      <div
        data-el="pattern-shell"
        class="flex items-center rounded-lg border border-zinc-700 bg-zinc-950 px-3 py-2.5 font-mono text-sm transition focus-within:border-indigo-400/60"
      >
        <span class="select-none text-zinc-500">/</span>
        <input
          id="rx-pattern"
          data-el="pattern"
          type="text"
          value={defaultRegex}
          spellcheck="false"
          autocomplete="off"
          class="min-w-0 flex-1 bg-transparent px-1 text-indigo-300 outline-none"
        />
        <span class="select-none text-zinc-500">/<span data-el="flag-display">{defaultFlags}</span></span>
      </div>
      <p data-el="error" hidden class="mt-2 rounded-md bg-red-500/10 px-3 py-2 font-mono text-xs text-red-400"></p>
    </div>

    <fieldset>
      <legend class="mb-2 text-sm font-semibold text-zinc-200">Flags</legend>
      <div class="flex flex-wrap gap-2">
        {
          flagDefs.map(({ flag, label }) => (
            <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-zinc-700 px-3 py-1.5 text-sm text-zinc-300 transition has-checked:border-indigo-400/60 has-checked:bg-indigo-500/10 has-checked:text-indigo-200">
              <input
                type="checkbox"
                data-flag={flag}
                checked={defaultFlags.includes(flag)}
                class="accent-indigo-400"
              />
              <span class="font-mono font-bold">{flag}</span>
              <span class="text-xs text-zinc-500">{label}</span>
            </label>
          ))
        }
      </div>
    </fieldset>

    <details class="group rounded-lg border border-zinc-800 bg-zinc-950/60" open>
      <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-zinc-200 select-none">
        Explanation — token breakdown
        <span class="text-zinc-500 transition group-open:rotate-180">▾</span>
      </summary>
      <ul data-el="explanation" class="space-y-1.5 border-t border-zinc-800 px-4 py-3 text-sm"></ul>
    </details>
  </section>

  <!-- Right: testing sandbox panel -->
  <section class="flex flex-col rounded-xl border border-zinc-800 bg-zinc-900/40 p-5">
    <div class="mb-2 flex items-center justify-between">
      <label for="rx-test" class="text-sm font-semibold text-zinc-200">Test string</label>
      <span
        data-el="counter"
        class="rounded-full bg-indigo-500/15 px-2.5 py-0.5 font-mono text-xs text-indigo-300"
      >
        Matches: 0
      </span>
    </div>
    <div class="relative h-80 grow overflow-hidden rounded-lg border border-zinc-700 bg-zinc-950 focus-within:border-indigo-400/60 lg:h-auto lg:min-h-96">
      <div
        data-el="backdrop"
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 overflow-auto px-4 py-3 font-mono text-sm leading-6 whitespace-pre-wrap break-words text-transparent"
      >
      </div>
      <textarea
        id="rx-test"
        data-el="test"
        spellcheck="false"
        class="absolute inset-0 size-full resize-none overflow-auto bg-transparent px-4 py-3 font-mono text-sm leading-6 whitespace-pre-wrap break-words text-zinc-200 caret-indigo-300 outline-none"
      >{testString}</textarea>
    </div>
    <p class="mt-2 text-xs text-zinc-500">
      Matching runs locally as you type — nothing you paste here leaves this tab.
    </p>
  </section>
</div>

<script>
  const root = document.getElementById('regex-sandbox')!;
  const el = <T extends HTMLElement>(name: string) => root.querySelector<T>(`[data-el="${name}"]`)!;

  const patternInput = el<HTMLInputElement>('pattern');
  const patternShell = el<HTMLDivElement>('pattern-shell');
  const flagDisplay = el<HTMLSpanElement>('flag-display');
  const errorEl = el<HTMLParagraphElement>('error');
  const explanationEl = el<HTMLUListElement>('explanation');
  const testArea = el<HTMLTextAreaElement>('test');
  const backdrop = el<HTMLDivElement>('backdrop');
  const counter = el<HTMLSpanElement>('counter');
  const copyBtn = el<HTMLButtonElement>('copy');
  const flagBoxes = [...root.querySelectorAll<HTMLInputElement>('[data-flag]')];

  const MAX_HIGHLIGHTS = 5000;
  const MARK_CLASS = 'rounded-sm bg-indigo-500/30 outline outline-1 outline-indigo-400/40';

  const escapeHtml = (s: string) =>
    s.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;');

  const currentFlags = () =>
    flagBoxes.filter((b) => b.checked).map((b) => b.dataset.flag).join('');

  function collectMatches(re: RegExp, text: string): RegExpMatchArray[] {
    if (re.flags.includes('g')) return [...text.matchAll(re)];
    const single = text.match(re);
    return single ? [single] : [];
  }

  function render() {
    const pattern = patternInput.value;
    const flags = currentFlags();
    const text = testArea.value;
    flagDisplay.textContent = flags;

    let re: RegExp | null = null;
    if (pattern !== '') {
      try {
        re = new RegExp(pattern, flags);
        errorEl.hidden = true;
        patternShell.classList.remove('border-red-500/60');
      } catch (err) {
        errorEl.textContent = err instanceof Error ? err.message : String(err);
        errorEl.hidden = false;
        patternShell.classList.add('border-red-500/60');
        backdrop.innerHTML = escapeHtml(text) + '\n';
        counter.textContent = 'Invalid regex';
        return;
      }
    } else {
      errorEl.hidden = true;
      patternShell.classList.remove('border-red-500/60');
    }

    let html = '';
    let cursor = 0;
    let count = 0;
    if (re) {
      for (const m of collectMatches(re, text)) {
        const index = m.index ?? 0;
        if (m[0] === '' || index < cursor) continue; // skip zero-length and overlapping matches
        if (count >= MAX_HIGHLIGHTS) break;
        html += escapeHtml(text.slice(cursor, index));
        html += `<mark class="${MARK_CLASS}">${escapeHtml(m[0])}</mark>`;
        cursor = index + m[0].length;
        count++;
      }
    }
    html += escapeHtml(text.slice(cursor));
    // trailing newline so the backdrop keeps height parity with the textarea's last empty line
    backdrop.innerHTML = html + '\n';
    counter.textContent = `Matches: ${count}${count >= MAX_HIGHLIGHTS ? '+' : ''}`;

    renderExplanation(pattern);
  }

  // --- Plain-English token breakdown -------------------------------------

  interface TokenNote {
    token: string;
    desc: string;
  }

  const ESCAPE_MAP: Record<string, string> = {
    d: 'any digit 0-9',
    D: 'any character that is not a digit',
    w: 'any word character (letter, digit, or underscore)',
    W: 'any non-word character',
    s: 'any whitespace character',
    S: 'any non-whitespace character',
    b: 'a word boundary (edge between a word and non-word character)',
    B: 'a position that is not a word boundary',
    n: 'a newline',
    t: 'a tab',
  };

  const QUANT_MAP: Record<string, string> = {
    '*': 'repeat the previous item 0 or more times',
    '+': 'repeat the previous item 1 or more times',
    '?': 'make the previous item optional (0 or 1 times)',
  };

  function explainRegex(pattern: string): TokenNote[] {
    const notes: TokenNote[] = [];
    const push = (token: string, desc: string) => notes.push({ token, desc });
    let i = 0;

    while (i < pattern.length && notes.length < 60) {
      const c = pattern[i];

      if (c === '\\') {
        const next = pattern[i + 1] ?? '';
        push('\\' + next, ESCAPE_MAP[next] ?? `the literal character "${next}"`);
        i += 2;
      } else if (c === '[') {
        let j = i + 1;
        if (pattern[j] === '^') j++;
        if (pattern[j] === ']') j++; // leading ] is a literal
        while (j < pattern.length && pattern[j] !== ']') j += pattern[j] === '\\' ? 2 : 1;
        const token = pattern.slice(i, j + 1);
        const negated = pattern[i + 1] === '^';
        const body = token.slice(negated ? 2 : 1, token.endsWith(']') ? -1 : undefined);
        push(token, `one character ${negated ? 'NOT ' : ''}from the set: ${body}`);
        i = j + 1;
      } else if (c === '(') {
        const groupTypes: [string, string][] = [
          ['(?:', 'start a non-capturing group'],
          ['(?=', 'lookahead — what follows must match this, without consuming it'],
          ['(?!', 'negative lookahead — what follows must NOT match this'],
          ['(?<=', 'lookbehind — what comes before must match this'],
          ['(?<!', 'negative lookbehind — what comes before must NOT match this'],
        ];
        const hit = groupTypes.find(([prefix]) => pattern.startsWith(prefix, i));
        if (hit) {
          push(hit[0], hit[1]);
          i += hit[0].length;
        } else {
          push('(', 'start a capturing group (saved for backreferences and extraction)');
          i += 1;
        }
      } else if (c === ')') {
        push(')', 'end of group');
        i += 1;
      } else if (c === '^') {
        push('^', 'anchor: start of the string (or start of a line with the m flag)');
        i += 1;
      } else if (c === '$') {
        push('$', 'anchor: end of the string (or end of a line with the m flag)');
        i += 1;
      } else if (c === '.') {
        push('.', 'any single character except a newline');
        i += 1;
      } else if (c === '|') {
        push('|', 'OR — match either the expression before or after this');
        i += 1;
      } else if (c === '*' || c === '+' || c === '?') {
        const lazy = pattern[i + 1] === '?';
        push(c + (lazy ? '?' : ''), QUANT_MAP[c] + (lazy ? ' — lazily, as few as possible' : ''));
        i += lazy ? 2 : 1;
      } else if (c === '{') {
        const close = pattern.indexOf('}', i);
        if (close === -1) {
          push('{', 'the literal character "{"');
          i += 1;
        } else {
          const lazy = pattern[close + 1] === '?';
          const token = pattern.slice(i, close + 1) + (lazy ? '?' : '');
          const [min, max] = pattern.slice(i + 1, close).split(',');
          const times =
            max === undefined ? `exactly ${min} times` : max === '' ? `${min} or more times` : `${min} to ${max} times`;
          push(token, `repeat the previous item ${times}${lazy ? ' — lazily' : ''}`);
          i = close + 1 + (lazy ? 1 : 0);
        }
      } else {
        let j = i;
        while (j < pattern.length && !'\\[](){}^$.|*+?'.includes(pattern[j])) j++;
        const literal = pattern.slice(i, j);
        push(literal, `the literal text "${literal}"`);
        i = j;
      }
    }
    return notes;
  }

  function renderExplanation(pattern: string) {
    explanationEl.replaceChildren(
      ...(pattern === ''
        ? [Object.assign(document.createElement('li'), { textContent: 'Type a pattern to see its breakdown.', className: 'text-zinc-500' })]
        : explainRegex(pattern).map(({ token, desc }) => {
            const li = document.createElement('li');
            li.className = 'flex gap-3';
            const code = document.createElement('code');
            code.className = 'shrink-0 rounded bg-zinc-800 px-1.5 py-0.5 font-mono text-xs text-indigo-300';
            code.textContent = token;
            const span = document.createElement('span');
            span.className = 'text-zinc-400';
            span.textContent = desc;
            li.append(code, span);
            return li;
          }))
    );
  }

  // --- Wiring -------------------------------------------------------------

  patternInput.addEventListener('input', render);
  testArea.addEventListener('input', render);
  flagBoxes.forEach((b) => b.addEventListener('change', render));
  testArea.addEventListener('scroll', () => {
    backdrop.scrollTop = testArea.scrollTop;
    backdrop.scrollLeft = testArea.scrollLeft;
  });
  copyBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(`/${patternInput.value}/${currentFlags()}`);
    copyBtn.textContent = 'copied!';
    setTimeout(() => (copyBtn.textContent = 'copy'), 1200);
  });

  render();
</script>
