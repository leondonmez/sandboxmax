---
/**
 * NetworkFooter.astro — cross-property "studio network" band.
 * Rendered site-wide from the global Layout. The current site (SandboxMax)
 * is marked active and rendered as a non-linking card to avoid self-links.
 */
interface NetworkSite {
  name: string;
  blurb: string;
  url: string;
  /** true for the site this footer is deployed on */
  current?: boolean;
}

const network: NetworkSite[] = [
  {
    name: 'SandboxMax',
    blurb: 'All-in-one developer sandbox & utility toolkit.',
    url: 'https://sandboxmax.com',
    current: true,
  },
  {
    name: 'CronCrunch',
    blurb: 'Visual cron expression generator and debugger.',
    url: 'https://croncrunch.dev',
  },
  {
    name: 'MockDock',
    blurb: 'Instant mock API endpoints and JSON hosting.',
    url: 'https://mockdock.dev',
  },
];

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-zinc-800/80 bg-zinc-950">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <p class="mb-5 font-mono text-xs tracking-wide text-zinc-500 uppercase">The network</p>

    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        network.map((site) =>
          site.current ? (
            <li
              aria-current="page"
              class="relative rounded-xl border border-emerald-400/40 bg-emerald-400/[0.06] p-5"
            >
              <span class="absolute top-4 right-4 rounded-full bg-emerald-400/15 px-2 py-0.5 font-mono text-[10px] font-semibold text-emerald-300">
                You are here
              </span>
              <p class="font-mono text-sm font-bold text-zinc-100">{site.name}</p>
              <p class="mt-1 max-w-[26ch] text-sm text-zinc-400">{site.blurb}</p>
            </li>
          ) : (
            <li>
              <a
                href={site.url}
                target="_blank"
                rel="noopener"
                class="group block h-full rounded-xl border border-zinc-800 bg-zinc-900/30 p-5 transition hover:border-indigo-400/40 hover:bg-zinc-900"
              >
                <p class="flex items-center gap-1.5 font-mono text-sm font-bold text-zinc-100 transition group-hover:text-indigo-300">
                  {site.name}
                  <span class="translate-y-px text-xs text-zinc-600 transition group-hover:translate-x-0.5 group-hover:text-indigo-300">
                    ↗
                  </span>
                </p>
                <p class="mt-1 text-sm text-zinc-500 transition group-hover:text-zinc-400">{site.blurb}</p>
              </a>
            </li>
          )
        )
      }
    </ul>

    <div class="mt-8 flex flex-col items-center justify-between gap-2 border-t border-zinc-800/60 pt-6 text-xs text-zinc-500 sm:flex-row">
      <p>&copy; {year} SandboxMax. Free forever, local forever.</p>
      <p>
        A product of{' '}
        <a
          href="https://vibs.io"
          target="_blank"
          rel="noopener"
          class="font-semibold text-zinc-400 underline decoration-zinc-700 underline-offset-2 transition hover:text-emerald-300 hover:decoration-emerald-400/50"
        >
          vibs.io
        </a>
      </p>
    </div>
  </div>
</footer>
