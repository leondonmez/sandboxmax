---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ToolSteps from '../../components/ToolSteps.astro';
import RegexSandbox from '../../components/RegexSandbox.astro';
import { regexTools } from '../../data/regexTools';

export function getStaticPaths() {
  return regexTools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const related = regexTools.filter((t) => t.slug !== tool.slug);
---

<Layout title={tool.metaTitle} description={tool.metaDescription} toolName={tool.toolTitle}>
  <SiteHeader />

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="mb-6 font-mono text-xs text-zinc-500">
      <a href="/" class="transition hover:text-zinc-300">sandboxmax</a>
      <span class="mx-1">/</span>
      <a href="/regex/tester" class="transition hover:text-zinc-300">regex</a>
      <span class="mx-1">/</span>
      <span class="text-zinc-400">{tool.slug}</span>
    </nav>

    <div class="mb-8 max-w-3xl">
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-50 sm:text-4xl">
        {tool.toolTitle}
      </h1>
      <p class="mt-3 leading-relaxed text-zinc-400">{tool.explanation}</p>
      <p class="mt-3 inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 font-mono text-xs text-emerald-300">
        <span class="size-1.5 rounded-full bg-emerald-400"></span>
        runs 100% in your browser — nothing is uploaded
      </p>
    </div>

    <ToolSteps toolName={tool.toolTitle} steps={[
          ['Paste your text', 'Drop your logs, code, or data into the test box on the right.'],
          ['Tweak the pattern', 'Edit the regex formula or toggle the g / i / m flags on the left.'],
          ['See matches instantly', 'Matching text lights up as you type, with a live counter.'],
        ]} />

    <RegexSandbox
      defaultRegex={tool.defaultRegex}
      defaultFlags={tool.defaultFlags}
      testString={tool.testString}
    />

    <section class="mt-8 rounded-xl border border-zinc-800 bg-zinc-900/40 p-5">
      <h2 class="mb-2 text-sm font-semibold text-zinc-200">
        Expected output <span class="font-normal text-zinc-500">— what the pre-loaded example matches</span>
      </h2>
      <pre class="overflow-auto rounded-lg bg-zinc-950 px-4 py-3 font-mono text-xs leading-5 whitespace-pre-wrap text-emerald-300/90">{tool.exampleOutput}</pre>
      <p class="mt-2 text-xs text-zinc-500">
        This is the result the sandbox above computes from its sample data — edit the pattern, flags, or test string
        and the live match counter recalculates instantly.
      </p>
    </section>

    {
      related.length > 0 && (
        <section class="mt-14">
          <h2 class="mb-4 text-lg font-bold text-zinc-100">More regex tools</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((t) => (
              <a
                href={`/regex/${t.slug}`}
                class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition hover:border-indigo-400/40 hover:bg-zinc-900"
              >
                <span class="font-mono text-xs text-zinc-500">/regex/{t.slug}</span>
                <h3 class="mt-1 font-semibold text-zinc-100 group-hover:text-indigo-300">{t.toolTitle}</h3>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>

  <SiteFooter />
</Layout>
