---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { tools } from '../data/tools';

const benefits = [
  {
    icon: '⚡',
    title: 'Zero friction',
    body: 'No sign-in walls, no pricing tiers, no upgrade banners. Every tool is live and interactive the millisecond the page loads.',
  },
  {
    icon: '🔒',
    title: '100% local execution',
    body: 'Everything runs on client-side JavaScript. Paste JWTs, corporate payloads, or private configs — your data never leaves this browser tab. Check the network panel; we dare you.',
  },
  {
    icon: '∞',
    title: 'Infinite iterations',
    body: 'No tokens, no credits, no metered anything. Run ten thousand variations, test edge cases for hours — it all executes on your CPU, for free, forever.',
  },
];
---

<Layout
  title="SandboxMax — The Client-Side Sandbox for Code Utilities"
  description="Free developer utilities that run 100% in your browser. No LLM costs, no accounts, no data leaving your machine. Format JSON, decode JWTs, test regex, and more."
>
  <SiteHeader />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_-10%,rgba(52,211,153,0.13),transparent)]"
      >
      </div>
      <div class="mx-auto max-w-6xl px-4 pt-20 pb-16 text-center sm:px-6 sm:pt-28">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3.5 py-1 font-mono text-xs text-emerald-300">
          <span class="size-1.5 rounded-full bg-emerald-400"></span>
          0 signups &middot; 0 servers &middot; 0 tokens
        </p>
        <h1 class="mx-auto max-w-3xl text-4xl font-extrabold tracking-tight text-zinc-50 sm:text-6xl">
          The Client-Side <span class="text-emerald-400">Sandbox</span>
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-zinc-400 sm:text-xl">
          No LLM costs. No accounts. Just pure code utilities — running entirely in <em class="text-zinc-200 not-italic font-semibold">your</em> browser.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a
            href="#tools"
            class="rounded-lg bg-emerald-400 px-6 py-3 font-semibold text-zinc-950 transition hover:bg-emerald-300"
          >
            Browse the tools
          </a>
          <a
            href="#why"
            class="rounded-lg border border-zinc-700 px-6 py-3 font-semibold text-zinc-300 transition hover:border-zinc-500 hover:text-zinc-100"
          >
            Why it&rsquo;s different
          </a>
        </div>

        <!-- Terminal proof card -->
        <div class="mx-auto mt-14 max-w-xl rounded-xl border border-zinc-800 bg-zinc-900/70 text-left shadow-2xl shadow-emerald-950/20">
          <div class="flex items-center gap-1.5 border-b border-zinc-800 px-4 py-2.5">
            <span class="size-2.5 rounded-full bg-zinc-700"></span>
            <span class="size-2.5 rounded-full bg-zinc-700"></span>
            <span class="size-2.5 rounded-full bg-zinc-700"></span>
            <span class="ml-2 font-mono text-xs text-zinc-500">network panel</span>
          </div>
          <div class="space-y-1.5 px-4 py-4 font-mono text-sm">
            <p class="text-zinc-500">$ requests sent after page load:</p>
            <p class="text-emerald-400">0</p>
            <p class="text-zinc-500">$ your data uploaded to a server:</p>
            <p class="text-emerald-400">never</p>
            <p class="text-zinc-600">— everything runs on your CPU. that&rsquo;s the whole trick.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section id="why" class="mx-auto max-w-6xl scroll-mt-20 px-4 py-16 sm:px-6">
      <div class="grid gap-5 sm:grid-cols-3">
        {
          benefits.map((b) => (
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6 transition hover:border-zinc-700">
              <div class="mb-3 flex size-10 items-center justify-center rounded-lg bg-emerald-400/10 text-xl text-emerald-400">
                {b.icon}
              </div>
              <h2 class="mb-2 text-lg font-bold text-zinc-100">{b.title}</h2>
              <p class="text-sm leading-relaxed text-zinc-400">{b.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Tool grid -->
    <section id="tools" class="mx-auto max-w-6xl scroll-mt-20 px-4 pt-4 pb-20 sm:px-6">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-zinc-50 sm:text-3xl">The workshop</h2>
          <p class="mt-2 text-zinc-400">Every tool below runs locally. Pick one and get to work.</p>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          tools.map((tool) => (
            <a
              href={tool.status === 'live' ? `/${tool.slug}` : undefined}
              class:list={[
                'group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition',
                tool.status === 'live'
                  ? 'hover:border-emerald-400/40 hover:bg-zinc-900'
                  : 'cursor-default opacity-70',
              ]}
            >
              <div class="mb-2 flex items-center justify-between gap-2">
                <span class="font-mono text-xs text-zinc-500">/{tool.slug}</span>
                {tool.status === 'live' ? (
                  <span class="rounded-full bg-emerald-400/15 px-2 py-0.5 font-mono text-[11px] text-emerald-300">
                    live
                  </span>
                ) : (
                  <span class="rounded-full bg-zinc-800 px-2 py-0.5 font-mono text-[11px] text-zinc-400">
                    soon
                  </span>
                )}
              </div>
              <h3 class="font-semibold text-zinc-100 group-hover:text-emerald-300">{tool.name}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-zinc-400">{tool.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
