---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ToolSteps from '../../components/ToolSteps.astro';
import MarkdownPreviewer from '../../components/MarkdownPreviewer.astro';
import { markdownTools } from '../../data/markdownTools';

export function getStaticPaths() {
  return markdownTools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const related = markdownTools.filter((t) => t.slug !== tool.slug);
---

<Layout title={tool.metaTitle} description={tool.metaDescription} toolName={tool.toolTitle}>
  <SiteHeader />

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="mb-6 font-mono text-xs text-zinc-500">
      <a href="/" class="transition hover:text-zinc-300">sandboxmax</a>
      <span class="mx-1">/</span>
      <a href="/markdown/preview-github-readme-template" class="transition hover:text-zinc-300">markdown</a>
      <span class="mx-1">/</span>
      <span class="text-zinc-400">{tool.slug}</span>
    </nav>

    <div class="mb-8 max-w-3xl">
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-50 sm:text-4xl">
        {tool.toolTitle}
      </h1>
      {tool.seo && <p class="mt-3 leading-relaxed text-zinc-300">{tool.seo.lead}</p>}
      <p class="mt-3 leading-relaxed text-zinc-400">{tool.explanation}</p>
      <p class="mt-3 inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 font-mono text-xs text-emerald-300">
        <span class="size-1.5 rounded-full bg-emerald-400"></span>
        runs 100% in your browser — your prose stays private
      </p>
    </div>

    {
      tool.seo && (
        <section class="mb-8 max-w-3xl">
          <h2 class="text-xl font-bold text-zinc-100">{tool.seo.h2}</h2>
          <p class="mt-2 leading-relaxed text-zinc-400">{tool.seo.intro}</p>
          <pre class="mt-3 overflow-x-auto rounded-lg border border-zinc-800 bg-zinc-950 px-4 py-3 font-mono text-sm text-emerald-300/90"><code>{tool.seo.code}</code></pre>
          <h3 class="mt-5 text-lg font-semibold text-zinc-100">{tool.seo.h3}</h3>
          <p class="mt-2 leading-relaxed text-zinc-400">{tool.seo.h3body}</p>
        </section>
      )
    }

    <ToolSteps toolName={tool.toolTitle} steps={[
          ['Write markdown', 'Type or paste on the left — the macro buttons drop tables, code blocks, and tasks at your cursor.'],
          ['Watch it render', 'The right pane re-renders on every keystroke in GitHub&rsquo;s dark style, scroll-synced to the editor.'],
          ['Copy the HTML', 'Word and character counts update live; one click copies the rendered HTML markup.'],
        ]} />

    <MarkdownPreviewer defaultMarkdown={tool.defaultMarkdown} />

    {
      related.length > 0 && (
        <section class="mt-14">
          <h2 class="mb-4 text-lg font-bold text-zinc-100">More markdown tools</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((t) => (
              <a
                href={`/markdown/${t.slug}`}
                class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition hover:border-indigo-400/40 hover:bg-zinc-900"
              >
                <span class="font-mono text-xs text-zinc-500">/markdown/{t.slug}</span>
                <h3 class="mt-1 font-semibold text-zinc-100 group-hover:text-indigo-300">{t.toolTitle}</h3>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>

  <SiteFooter />
</Layout>
