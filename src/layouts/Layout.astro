---
import '../styles/global.css';
import NetworkFooter from '../components/NetworkFooter.astro';

interface Props {
  title: string;
  description: string;
  /** when set, the page is a tool and emits SoftwareApplication JSON-LD */
  toolName?: string;
  /** error/utility pages: keep bots out of the index but still following links */
  noindex?: boolean;
}

const { title, description, toolName, noindex = false } = Astro.props;

const schema = toolName
  ? {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: toolName,
      description,
      url: new URL(Astro.url.pathname, Astro.site).href,
      operatingSystem: 'All',
      applicationCategory: 'DeveloperApplication',
      browserRequirements: 'Requires JavaScript. Runs 100% client-side inside the browser thread.',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'SandboxMax',
      description,
      url: Astro.site?.href,
    };
---

<html lang="en" class="scheme-dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="flex min-h-screen flex-col bg-zinc-950 text-zinc-300 antialiased selection:bg-emerald-400/30">
    <slot />
    <NetworkFooter />
  </body>
</html>
