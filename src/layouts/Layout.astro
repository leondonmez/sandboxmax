---
import '../styles/global.css';
import NetworkFooter from '../components/NetworkFooter.astro';

interface Props {
  title: string;
  description: string;
  /** when set, the page is a tool and emits SoftwareApplication JSON-LD */
  toolName?: string;
  /** error/utility pages: keep bots out of the index but still following links */
  noindex?: boolean;
}

const { title, description, toolName, noindex = false } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// each tool page has a build-time generated OG card; landing + 404 share the site card
const ogSlug = Astro.url.pathname.replace(/^\/|\/$/g, '');
const ogImage = new URL(`/open-graph/${ogSlug === '' || ogSlug === '404' ? 'site' : ogSlug}.png`, Astro.site).href;

// AEO: the privacy question every paste-sensitive-data tool user asks.
// Single source of truth — rendered visibly on the page AND embedded in the
// FAQPage schema below, so structured data can never drift from on-page text.
const faq = toolName
  ? {
      question: `Is it safe to paste sensitive data into the ${toolName}?`,
      answer: `Yes. The ${toolName} runs 100% client-side inside your browser thread — nothing you paste is uploaded, logged, or transmitted. SandboxMax is a static site with no backend server, no cookies, and no trackers: open your browser's network panel while you work and you'll see zero requests leave the tab.`,
    }
  : null;

// one coherent JSON-LD graph per tool page: entities carry @ids and reference
// each other instead of shipping as disjoint schema blocks
const schema = toolName
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'SoftwareApplication',
          '@id': `${canonicalUrl}#software`,
          name: toolName,
          description,
          url: canonicalUrl,
          operatingSystem: 'All',
          applicationCategory: 'DeveloperApplication',
          browserRequirements: 'Requires JavaScript. Runs 100% client-side inside the browser thread.',
          offers: {
            '@type': 'Offer',
            price: '0',
            priceCurrency: 'USD',
          },
        },
        {
          '@type': 'FAQPage',
          '@id': `${canonicalUrl}#faq`,
          about: { '@id': `${canonicalUrl}#software` },
          mainEntity: [
            {
              '@type': 'Question',
              name: faq!.question,
              acceptedAnswer: { '@type': 'Answer', text: faq!.answer },
            },
          ],
        },
      ],
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'SandboxMax',
      description,
      url: Astro.site?.href,
    };
---

<html lang="en" class="scheme-dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SandboxMax" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="flex min-h-screen flex-col bg-zinc-950 text-zinc-300 antialiased selection:bg-emerald-400/30">
    <slot />
    {
      faq && (
        <section aria-label="Privacy FAQ" class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6">
          <h2 class="mb-2 text-sm font-semibold text-zinc-200">{faq.question}</h2>
          <p class="max-w-3xl text-sm leading-relaxed text-zinc-400">{faq.answer}</p>
        </section>
      )
    }
    <NetworkFooter />
  </body>
</html>
